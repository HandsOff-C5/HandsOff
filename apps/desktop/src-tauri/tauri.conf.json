{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HandsOff",
  "version": "0.0.0",
  "identifier": "com.handsoff.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @handsoff/desktop-app dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --filter @handsoff/desktop-app build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "HandsOff",
        "width": 1280,
        "height": 800,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/stt-ondevice"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
