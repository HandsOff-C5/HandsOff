<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Embedded into the on-device STT sidecar's Mach-O `__TEXT,__info_plist` section
  by sidecars/build.sh and build.rs (#31). macOS aborts any process that touches
  microphone / speech recognition without these usage strings, so the helper
  needs its own copy — the app bundle's Info.plist does not cover a separate
  executable. CFBundleName makes the TCC prompt read "HandsOff".
-->
<plist version="1.0">
  <dict>
    <key>CFBundleName</key>
    <string>HandsOff</string>
    <key>CFBundleIdentifier</key>
    <string>com.handsoff.desktop.stt</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>HandsOff uses your microphone while you push to talk, turning spoken commands into on-device transcripts.</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>HandsOff transcribes your speech on this device to turn spoken commands into agent tasks. Audio is processed on-device and is not sent to a server.</string>
  </dict>
</plist>
