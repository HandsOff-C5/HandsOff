{
  "$schema": "https://unpkg.com/knip@5/schema.jsonc",
  "ignoreExportsUsedInFile": true,
  "ignoreBinaries": ["codesign", "open"],
  "workspaces": {
    "packages/*": {
      "entry": ["src/index.ts!", "src/**/*.test.ts"],
      "project": "src/**/*.ts"
    },
    "apps/desktop": {
      "entry": [
        "src/main.tsx!",
        "vite.config.ts",
        "vitest.config.ts",
        "src-tauri/**",
        "scripts/**"
      ],
      "project": "src/**/*.{ts,tsx}"
    }
  }
}
